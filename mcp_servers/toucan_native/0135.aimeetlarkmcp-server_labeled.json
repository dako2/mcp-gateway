                    "value": {
                      "type": "string",
                      "enum": [
                        "yes",
                        "maybe",
                        "no"
                      ],
                      "description": "Vote value"
                    }
                  },
                  "required": [
                    "timeSlotId",
                    "value"
                  ]
                },
                "description": "Votes for each time slot"
              }
            },
            "required": [
              "participateToken",
